# 复制为 .env 后填入真实值，.env 不要提交到版本库

# ====== 大模型 API 配置（OpenAI 兼容接口） ======
# DeepSeek 示例：
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
# Kimi (Moonshot) 示例：
#   LLM_BASE_URL=https://api.moonshot.cn/v1
#   LLM_MODEL=moonshot-v1-8k
# Qwen (DashScope 兼容模式) 示例：
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen-plus

LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat


# 辅助任务专用 API 配置（可选，留空则使用主 LLM 的配置）
# 示例：使用 DeepSeek 做主对话，用更便宜的模型做摘要
# LLM_LIGHT_BASE_URL=https://api.deepseek.com/v1
# LLM_LIGHT_API_KEY=sk-xxx
# LLM_LIGHT_MODEL=deepseek-chat
LLM_LIGHT_BASE_URL=
LLM_LIGHT_API_KEY=
LLM_LIGHT_MODEL=

# ====== OpenAI Speech 配置（可选） ======
# 与主对话模型独立；未配置 SPEECH_API_KEY 时语音接口返回未配置错误。
SPEECH_API_KEY=
SPEECH_BASE_URL=https://api.openai.com/v1
SPEECH_STT_MODEL=gpt-4o-mini-transcribe
SPEECH_TTS_MODEL=gpt-4o-mini-tts
SPEECH_OUTPUT_FORMAT=wav
SPEECH_STORAGE_PATH=./data/speech

# ====== 应用配置 ======
# 数据库文件路径（SQLite，零配置，适合开发/验证阶段）
DATABASE_PATH=./data/sqlite_db/memoria.db
# PostgreSQL 连接串（生产部署可选；留空时使用 SQLite）
# DATABASE_URL=postgresql://memoria:password@127.0.0.1:5432/memoria
DATABASE_URL=

# Cookie 安全标志；本地 HTTP 开发保持 false，HTTPS 部署可设为 true
AUTH_COOKIE_SECURE=false

# 短期记忆窗口大小（保留最近几轮对话）
SHORT_TERM_MEMORY_TURNS=8

# 单轮对话最大输出 token 数
MAX_OUTPUT_TOKENS=600

# ====== 向量数据库配置 ======
# 向量数据库存储路径（ChromaDB 数据文件目录）
VECTOR_DB_PATH=./data/chroma_db

# 嵌入模型（用于语义检索，支持本地路径）
EMBEDDING_MODEL=./models/sentence-transformers/all-MiniLM-L6-v2

# 向量检索返回的最大结果数
VECTOR_SEARCH_TOP_K=10
