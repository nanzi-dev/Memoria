# 复制为 .env 后填入真实值，.env 不要提交到版本库

# ====== 大模型 API 配置（OpenAI 兼容接口） ======
# DeepSeek 示例：
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
# Kimi (Moonshot) 示例：
#   LLM_BASE_URL=https://api.moonshot.cn/v1
#   LLM_MODEL=moonshot-v1-8k
# Qwen (DashScope 兼容模式) 示例：
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen-plus

LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat


# 辅助任务专用 API 配置（可选，留空则使用主 LLM 的配置）
# 示例：使用 DeepSeek 做主对话，用更便宜的模型做摘要
# LLM_LIGHT_BASE_URL=https://api.deepseek.com/v1
# LLM_LIGHT_API_KEY=sk-xxx
# LLM_LIGHT_MODEL=deepseek-chat
LLM_LIGHT_BASE_URL=
LLM_LIGHT_API_KEY=
LLM_LIGHT_MODEL=
LLM_TIMEOUT_SECONDS=45
LLM_LIGHT_TIMEOUT_SECONDS=12

# ====== Speech 配置（可选） ======
# TTS 和 STT 独立配置。默认 TTS 为 MiniMax 流式合成，默认 STT 为 OpenAI-compatible。
# 未配置对应密钥时，该能力会返回 503；LLM_API_KEY 不会自动复用。
SPEECH_TTS_PROVIDER=minimax
SPEECH_TTS_API_KEY=
SPEECH_TTS_BASE_URL=https://api.minimax.io/v1
SPEECH_TTS_MODEL=speech-2.8-turbo
SPEECH_TTS_TIMEOUT_SECONDS=30
SPEECH_TTS_MAX_RETRIES=1
SPEECH_TTS_DEFAULT_VOICE=female-shaonv
# 逗号分隔，供角色编辑器显示内置音色列表
SPEECH_TTS_BUILTIN_VOICES=male-qn-qingse,male-qn-jingying,male-qn-badao,male-qn-daxuesheng,female-shaonv,female-yujie,female-chengshu,female-tianmei

SPEECH_STT_PROVIDER=openai_compatible
SPEECH_STT_API_KEY=
SPEECH_STT_BASE_URL=https://api.openai.com/v1
SPEECH_STT_MODEL=gpt-4o-mini-transcribe
SPEECH_STT_TIMEOUT_SECONDS=30
SPEECH_STT_MAX_RETRIES=1
SPEECH_OUTPUT_FORMAT=mp3
SPEECH_STORAGE_PATH=./data/speech

# 兼容旧部署（已弃用）：SPEECH_PROVIDER、SPEECH_API_KEY、SPEECH_BASE_URL 和
# SPEECH_TIMEOUT_SECONDS 会在新的 TTS/STT 密钥为空时作为回退；请迁移到以上配置。

# ====== 应用配置 ======
# 数据库文件路径（SQLite，零配置，适合开发/验证阶段）
DATABASE_PATH=./data/sqlite_db/memoria.db
# PostgreSQL 连接串（生产部署可选；留空时使用 SQLite）
# DATABASE_URL=postgresql://memoria:password@127.0.0.1:5432/memoria
DATABASE_URL=

# Cookie 安全标志；本地 HTTP 开发保持 false，HTTPS 部署必须设为 true
AUTH_COOKIE_SECURE=false

# 短期记忆窗口大小（保留最近几轮对话）
SHORT_TERM_MEMORY_TURNS=8

# 单轮对话最大输出 token 数
MAX_OUTPUT_TOKENS=600

# ====== 向量数据库配置 ======
# 向量数据库存储路径（ChromaDB 数据文件目录）
VECTOR_DB_PATH=./data/chroma_db

# 嵌入模型（用于语义检索，支持本地路径）
EMBEDDING_MODEL=./models/sentence-transformers/all-MiniLM-L6-v2

# 向量检索返回的最大结果数
VECTOR_SEARCH_TOP_K=10
