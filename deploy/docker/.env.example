# Copy to .env before docker compose up. Set a real LLM API key and PostgreSQL password.
# docker-compose.yml also works with defaults, but LLM_API_KEY is required for real dialogue.

# ====== LLM provider ======
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Optional light model for summaries/evaluation.
LLM_LIGHT_BASE_URL=
LLM_LIGHT_API_KEY=
LLM_LIGHT_MODEL=
LLM_TIMEOUT_SECONDS=45
LLM_LIGHT_TIMEOUT_SECONDS=12
LIGHT_TASK_MAX_OUTPUT_TOKENS=400

# ====== Speech (optional) ======
# TTS and STT use separate credentials. TTS defaults to MiniMax streaming MP3.
SPEECH_TTS_PROVIDER=minimax
SPEECH_TTS_API_KEY=
SPEECH_TTS_BASE_URL=https://api.minimax.io/v1
SPEECH_TTS_MODEL=speech-2.8-turbo
SPEECH_TTS_TIMEOUT_SECONDS=30
SPEECH_TTS_MAX_RETRIES=1
SPEECH_TTS_DEFAULT_VOICE=female-shaonv
SPEECH_TTS_BUILTIN_VOICES=male-qn-qingse,male-qn-jingying,male-qn-badao,male-qn-daxuesheng,female-shaonv,female-yujie,female-chengshu,female-tianmei
SPEECH_STT_PROVIDER=openai_compatible
SPEECH_STT_API_KEY=
SPEECH_STT_BASE_URL=https://api.openai.com/v1
SPEECH_STT_MODEL=gpt-4o-mini-transcribe
SPEECH_STT_TIMEOUT_SECONDS=30
SPEECH_STT_MAX_RETRIES=1
SPEECH_OUTPUT_FORMAT=mp3
SPEECH_STORAGE_PATH=/app/data/speech
SPEECH_STT_UPLOAD_MAX_BYTES=26214400
SPEECH_CUSTOM_VOICE_UPLOAD_MAX_BYTES=10485760
SPEECH_CACHE_MAX_AGE_SECONDS=604800
SPEECH_CACHE_MAX_BYTES=536870912

# ====== Docker ports ======
WEB_PORT=8080
API_BIND_HOST=127.0.0.1
API_PORT=8001

# ====== PostgreSQL container ======
POSTGRES_DB=memoria
POSTGRES_USER=memoria
# Required. Use a unique, high-entropy password.
POSTGRES_PASSWORD=change-me

# ====== App settings ======
# Keep false for local HTTP; HTTPS deployments must set true.
AUTH_COOKIE_SECURE=false
SHORT_TERM_MEMORY_TURNS=8
LONG_TERM_MEMORY_INTERVAL_TURNS=5
MAX_OUTPUT_TOKENS=400
WORLD_CLOCK_DEFAULT_TIMEZONE=UTC
WORLD_CLOCK_SCHEDULER_INTERVAL_SECONDS=30
WORLD_CLOCK_SCHEDULER_LEASE_SECONDS=90
VECTOR_SEARCH_TOP_K=10
LOG_LEVEL=INFO

# Default Docker mode downloads and caches the embedding model on first vector use.
# To use a local model mounted from ../../models, set:
# EMBEDDING_MODEL=./models/sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ====== Knowledge base / RAG ======
KNOWLEDGE_STORAGE_PATH=/app/data/knowledge
KNOWLEDGE_QUERY_MAX_CHARS=4000
KNOWLEDGE_RETRIEVAL_TOP_K=4
KNOWLEDGE_MAX_CHUNKS_PER_DOCUMENT=3
KNOWLEDGE_SIMILARITY_THRESHOLD=0.60
KNOWLEDGE_INJECTION_MAX_CHARS=4000
KNOWLEDGE_UPLOAD_MAX_BYTES=10485760
KNOWLEDGE_PDF_MAX_PAGES=300
KNOWLEDGE_EXTRACT_MAX_CHARS=1000000
KNOWLEDGE_CHUNK_TARGET_TOKENS=200
KNOWLEDGE_CHUNK_OVERLAP_TOKENS=36
KNOWLEDGE_CHUNK_MAX_TOKENS=240
