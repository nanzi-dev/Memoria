# Copy to .env before docker compose up, then fill in real values.
# docker-compose.yml also works with defaults, but LLM_API_KEY is required for real dialogue.

# ====== LLM provider ======
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Optional light model for summaries/evaluation.
LLM_LIGHT_BASE_URL=
LLM_LIGHT_API_KEY=
LLM_LIGHT_MODEL=

# ====== Docker ports ======
WEB_PORT=8080
API_PORT=8001

# ====== PostgreSQL container ======
POSTGRES_DB=memoria
POSTGRES_USER=memoria
POSTGRES_PASSWORD=change-me

# ====== App settings ======
AUTH_COOKIE_SECURE=false
SHORT_TERM_MEMORY_TURNS=8
MAX_OUTPUT_TOKENS=600
VECTOR_SEARCH_TOP_K=10
LOG_LEVEL=INFO

# Default Docker mode downloads and caches the embedding model on first vector use.
# To use a local model mounted from ../../models, set:
# EMBEDDING_MODEL=./models/sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
